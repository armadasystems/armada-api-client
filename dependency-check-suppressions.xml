<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        CVE-2025-15104 (CVSS 6.9 MEDIUM) - hibernate-validator 8.0.x
        No fixed version available in the 8.0.x line.
        hibernate-validator 9.x requires Jakarta EE 11, incompatible with Spring Boot 3.x (Jakarta EE 10).
        Accepted risk: Spring Boot 3.x will provide an upgrade path when a patch is available.
        Review: revisit when Spring Boot 3.5+ ships or a hibernate-validator 8.0.4+ is released.
    -->
    <suppress>
        <notes>CVE-2025-15104 affects all hibernate-validator 8.0.x versions. No patched 8.0.x available.
        9.x requires Jakarta EE 11 which is incompatible with Spring Boot 3.x. Accepted risk.</notes>
        <packageUrl regex="true">^pkg:maven/org\.hibernate\.validator/hibernate\-validator@.*$</packageUrl>
        <cve>CVE-2025-15104</cve>
    </suppress>

</suppressions>
